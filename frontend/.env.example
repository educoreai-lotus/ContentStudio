# Backend API base URL (required for API calls and logo assets)
VITE_API_BASE_URL=http://localhost:3000

# nAuth API base URL (used for logout: POST /auth/logout with credentials)
VITE_NAUTH_BASE_URL=https://nauth-api.example.com

# nAuth frontend base URL (redirect target after logout: /login)
VITE_NAUTH_FRONTEND_URL=https://nauth.example.com
